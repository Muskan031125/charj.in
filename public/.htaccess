# ============================================================
# Charj.in - India's EV Marketplace
# Apache .htaccess for CodeIgniter 4
# Enables clean URLs (no /index.php in URL)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set the base path if the application is in a subdirectory.
    RewriteBase /Charj/public/

    # Redirect to HTTPS in production (uncomment when SSL is configured)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Redirect www to non-www (uncomment for production)
    # RewriteCond %{HTTP_HOST} ^www\.charj\.in [NC]
    # RewriteRule ^(.*)$ https://charj.in/$1 [L,R=301]

    # --------------------------------------------------------
    # Block direct access to sensitive files
    # --------------------------------------------------------
    RewriteRule ^(\.env|composer\.(json|lock)|\.git|writable/) - [F,L]

    # --------------------------------------------------------
    # Allow existing files and directories to be served directly
    # (CSS, JS, images, fonts, etc. in /public/assets/)
    # --------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # --------------------------------------------------------
    # Route all other requests through CodeIgniter's index.php
    # --------------------------------------------------------
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    # If mod_rewrite is not available, show a helpful error.
    # You may also set the $indexPage = 'index.php' in App.php
    # and use index.php in your URLs.
    ErrorDocument 403 "mod_rewrite is not enabled. Please enable it in Apache config or use index.php in your URLs."
</IfModule>

# --------------------------------------------------------
# Security Headers
# --------------------------------------------------------
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --------------------------------------------------------
# Performance: Browser Caching for Static Assets
# --------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
</IfModule>

# --------------------------------------------------------
# Performance: Gzip Compression
# --------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --------------------------------------------------------
# Disable directory browsing
# --------------------------------------------------------
Options -Indexes

# --------------------------------------------------------
# Protect .htaccess itself
# --------------------------------------------------------
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>
